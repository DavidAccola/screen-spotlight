{
  "enabled": true,
  "name": "Kill SpotlightOverlay Before Build",
  "description": "Automatically kills any running SpotlightOverlay.exe process before shell commands are executed, preventing file lock errors during builds.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": [
      "shell"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "taskkill /IM SpotlightOverlay.exe /F >nul 2>&1 & exit /b 0"
  }
}