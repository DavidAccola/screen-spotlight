<Window x:Class="SpotlightOverlay.Windows.FlyoutToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#434343" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505050" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!--
    Architecture:
    - The window is always sized to: nub + toolbar panel
    - For Left/Right anchor: nub is a narrow vertical strip, toolbar is beside it
    - When collapsed (Right anchor): window is positioned so only the nub peeks
      out from the right edge; the toolbar portion is off-screen to the left
    - On expand: animate Window.Left to slide the toolbar on-screen
    - The nub is draggable to reposition along the edge
    
    Layout for Right anchor (default):
    [ToolbarPanel | NubHandle]  ← nub is on the right, toolbar on the left
    
    Layout for Left anchor:
    [NubHandle | ToolbarPanel]  ← nub is on the left, toolbar on the right
    
    Layout for Top anchor:
    [NubHandle]     ← nub on top
    [ToolbarPanel]  ← toolbar below
    -->

    <Grid x:Name="RootGrid">
        <!-- For Left/Right: two columns. For Top: two rows. Set in code-behind. -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="Col0" Width="Auto" />
            <ColumnDefinition x:Name="Col1" Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="Row0" Height="Auto" />
            <RowDefinition x:Name="Row1" Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Nub Handle -->
        <Border x:Name="NubHandle" Background="#CC222222"
                Cursor="SizeAll" Padding="2,0"
                VerticalAlignment="Top" HorizontalAlignment="Left">
            <TextBlock x:Name="GripDots" Text="⋮" FontSize="11"
                       Foreground="#80FFFFFF" HorizontalAlignment="Center"
                       VerticalAlignment="Center" IsHitTestVisible="False" />
        </Border>

        <!-- Toolbar Panel -->
        <Border x:Name="ToolbarPanel" Background="#CC222222" CornerRadius="6"
                Padding="0">
            <!-- Outer wrapper provides drag zones on perpendicular edges -->
            <Border x:Name="ToolbarDragBorder" Background="Transparent"
                    Cursor="SizeAll" Padding="0">
                <StackPanel x:Name="ButtonPanel" Orientation="Vertical" Margin="4"
                            KeyboardNavigation.TabNavigation="Cycle">

                <!-- Top/Left drag zone -->
                <Border x:Name="DragZoneStart" Background="Transparent"
                        Cursor="SizeAll" />

                <Button x:Name="SpotlightButton"
                        AutomationProperties.Name="Spotlight"
                        Style="{StaticResource ToolbarButton}">
                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="SpotlightIcon" Width="26" Height="26" HorizontalAlignment="Center"/>
                        <TextBlock Text="Spotlight" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0" />
                    </StackPanel>
                </Button>

                <Button x:Name="ArrowButton"
                        AutomationProperties.Name="Arrow"
                        Style="{StaticResource ToolbarButton}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x279C;" FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock Text="Arrow" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0" />
                    </StackPanel>
                </Button>

                <Button x:Name="BoxButton"
                        AutomationProperties.Name="Box"
                        Style="{StaticResource ToolbarButton}">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Sharp-cornered rectangle, matching the actual box tool -->
                        <Viewbox Width="15" Height="15" HorizontalAlignment="Center">
                            <Rectangle Width="16" Height="13" Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                        </Viewbox>
                        <TextBlock Text="Box" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0" />
                    </StackPanel>
                </Button>

                <Button x:Name="HighlightButton"
                        AutomationProperties.Name="Highlight"
                        Style="{StaticResource ToolbarButton}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F58D;" FontSize="15" HorizontalAlignment="Center" />
                        <TextBlock Text="Highlighter" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0" />
                    </StackPanel>
                </Button>

                <Button x:Name="StepsButton"
                        AutomationProperties.Name="Steps"
                        Style="{StaticResource ToolbarButton}">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Teardrop matching actual geometry: large arc top, quadratic bezier sides to tip -->
                        <!-- Canvas 18×26: center=(9,8), radius=7, tail down, tip at (9,23.4) -->
                        <Viewbox Width="18" Height="22" HorizontalAlignment="Center">
                            <Grid Width="18" Height="26">
                                <Path Fill="White" Stroke="Transparent">
                                    <Path.Data>
                                        <!-- Start at left touch point (2,8), large clockwise arc to right (16,8),
                                             quadratic bezier via (16,13.1) to tip (9,23.4),
                                             quadratic bezier via (2,13.1) back to start -->
                                        <PathGeometry>
                                            <PathFigure StartPoint="2,8" IsClosed="True">
                                                <ArcSegment Point="16,8" Size="7,7" IsLargeArc="True" SweepDirection="Clockwise"/>
                                                <QuadraticBezierSegment Point1="16,13.1" Point2="9,23.4"/>
                                                <QuadraticBezierSegment Point1="2,13.1" Point2="2,8"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                </Path>
                                <TextBlock Text="1" FontSize="10" FontWeight="Bold"
                                           Foreground="#CC222222"
                                           HorizontalAlignment="Center" VerticalAlignment="Top"
                                           Margin="0,2,0,0" IsHitTestVisible="False"/>
                            </Grid>
                        </Viewbox>
                        <TextBlock Text="Steps" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0" />
                    </StackPanel>
                </Button>

                <Border x:Name="Separator" Height="1" Background="#40FFFFFF"
                        Margin="8,4" HorizontalAlignment="Stretch" />

                <Button x:Name="SettingsButton"
                        AutomationProperties.Name="Settings"
                        Style="{StaticResource ToolbarButton}">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Modern 8-tooth settings gear with circular center hole, EvenOdd fill -->
                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                            <Path Fill="White" Stretch="Uniform">
                                <Path.Data>
                                    <PathGeometry FillRule="EvenOdd"
                                        Figures="M 12,15.5 C 10.07,15.5 8.5,13.93 8.5,12 C 8.5,10.07 10.07,8.5 12,8.5 C 13.93,8.5 15.5,10.07 15.5,12 C 15.5,13.93 13.93,15.5 12,15.5 Z M 19.43,12.97 C 19.47,12.65 19.5,12.33 19.5,12 C 19.5,11.67 19.47,11.34 19.43,11.03 L 21.54,9.37 C 21.73,9.22 21.78,8.95 21.66,8.73 L 19.66,5.27 C 19.54,5.05 19.27,4.97 19.05,5.05 L 16.56,6.05 C 16.04,5.65 15.48,5.32 14.87,5.07 L 14.49,2.42 C 14.46,2.18 14.25,2 14,2 L 10,2 C 9.75,2 9.54,2.18 9.51,2.42 L 9.13,5.07 C 8.52,5.32 7.96,5.66 7.44,6.05 L 4.95,5.05 C 4.72,4.96 4.46,5.05 4.34,5.27 L 2.34,8.73 C 2.21,8.95 2.27,9.22 2.46,9.37 L 4.57,11.03 C 4.53,11.34 4.5,11.67 4.5,12 C 4.5,12.33 4.53,12.65 4.57,12.97 L 2.46,14.63 C 2.27,14.78 2.21,15.05 2.34,15.27 L 4.34,18.73 C 4.46,18.95 4.73,19.03 4.95,18.95 L 7.44,17.95 C 7.96,18.35 8.52,18.68 9.13,18.93 L 9.51,21.58 C 9.54,21.82 9.75,22 10,22 L 14,22 C 14.25,22 14.46,21.82 14.49,21.58 L 14.87,18.93 C 15.48,18.68 16.04,18.34 16.56,17.95 L 19.05,18.95 C 19.28,19.04 19.54,18.95 19.66,18.73 L 21.66,15.27 C 21.78,15.05 21.73,14.78 21.54,14.63 Z"/>
                                </Path.Data>
                            </Path>
                        </Viewbox>
                        <TextBlock Text="Settings" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0" />
                    </StackPanel>
                </Button>

                <!-- Bottom/Right drag zone -->
                <Border x:Name="DragZoneEnd" Background="Transparent"
                        Cursor="SizeAll" />

            </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
