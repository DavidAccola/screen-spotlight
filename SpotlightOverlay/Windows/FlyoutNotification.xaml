<Window x:Class="SpotlightOverlay.Windows.FlyoutNotification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize"
        Width="280" Height="44">
    <Border x:Name="Container" Background="#E6222222" CornerRadius="6,0,0,6"
            BorderBrush="#33FFFFFF" BorderThickness="1,1,0,1" Padding="14,0">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.5" Direction="270" />
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Border x:Name="IconContainer" Width="18" Height="18"
                    VerticalAlignment="Center"
                    Margin="0,0,6,0" Visibility="Collapsed" />
            <TextBlock x:Name="MessageText" Foreground="#E0E0E0" FontSize="13"
                       VerticalAlignment="Center" HorizontalAlignment="Left" />
        </StackPanel>
    </Border>
</Window>
