<Window x:Class="SpotlightOverlay.Windows.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Colors"
        Width="340" Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#2D2D2D" />
        <SolidColorBrush x:Key="CardBorder" Color="#3E3E3E" />
        <SolidColorBrush x:Key="TextPrimary" Color="#E0E0E0" />
        <SolidColorBrush x:Key="TextSecondary" Color="#999999" />
        <SolidColorBrush x:Key="Accent" Color="#5B9BD5" />
        <SolidColorBrush x:Key="ControlBg" Color="#383838" />
        <SolidColorBrush x:Key="ControlHover" Color="#434343" />
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                CornerRadius="4" Padding="6,4">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <StackPanel Margin="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="24" />
            </Grid.ColumnDefinitions>

            <!-- Saturation/Value square -->
            <Grid x:Name="SvContainer" Grid.Column="0" Height="220" Cursor="Cross"
                  MouseLeftButtonDown="SvContainer_MouseLeftButtonDown"
                  MouseLeftButtonUp="SvContainer_MouseLeftButtonUp">
                <Border Background="Black" />
                <Border x:Name="SvHueLayer" Background="Red" />
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="White" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0" />
                            <GradientStop Color="Black" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Canvas IsHitTestVisible="False">
                    <Ellipse x:Name="SvCrosshair" Width="12" Height="12"
                             Stroke="White" StrokeThickness="2" Fill="Transparent" />
                </Canvas>
            </Grid>

            <!-- Hue bar -->
            <Border x:Name="HueBarBorder" Grid.Column="2" Width="24" Height="220" Cursor="Hand"
                    MouseLeftButtonDown="HueBar_MouseLeftButtonDown"
                    MouseLeftButtonUp="HueBar_MouseLeftButtonUp">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFF0000" Offset="0" />
                        <GradientStop Color="#FFFFFF00" Offset="0.167" />
                        <GradientStop Color="#FF00FF00" Offset="0.333" />
                        <GradientStop Color="#FF00FFFF" Offset="0.5" />
                        <GradientStop Color="#FF0000FF" Offset="0.667" />
                        <GradientStop Color="#FFFF00FF" Offset="0.833" />
                        <GradientStop Color="#FFFF0000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Canvas IsHitTestVisible="False">
                    <Border x:Name="HueIndicator" Width="24" Height="4"
                            Background="White" BorderBrush="Black" BorderThickness="1" />
                </Canvas>
            </Border>
        </Grid>

        <!-- Hex input + preview + OK/Cancel -->
        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="#" Foreground="{StaticResource TextSecondary}"
                       FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox Grid.Column="1" x:Name="HexColorInput" Width="80" FontSize="13"
                     MaxLength="6" CharacterCasing="Upper" TextAlignment="Center"
                     KeyDown="HexColorInput_KeyDown" LostFocus="HexColorInput_LostFocus" />
            <Border Grid.Column="2" x:Name="ColorPreview" Width="28" Height="28"
                    CornerRadius="14" Margin="10,0,0,0" HorizontalAlignment="Left"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1" />
            <Button Grid.Column="3" Content="OK" Click="OK_Click" Width="60" Margin="0,0,6,0"
                    Foreground="{StaticResource TextPrimary}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{StaticResource Accent}" CornerRadius="4" Padding="8,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="4" Content="Cancel" Click="Cancel_Click" Width="60"
                    Foreground="{StaticResource TextSecondary}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{StaticResource ControlBg}" CornerRadius="4" Padding="8,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </StackPanel>
</Window>
