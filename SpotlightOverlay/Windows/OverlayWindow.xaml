<Window x:Class="SpotlightOverlay.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid>
        <!-- Dark overlay with clip geometry + blur for feathered cutouts -->
        <Border x:Name="OverlayBorder" />
        <Canvas x:Name="PreviewCanvas">
            <Border x:Name="DragPreview"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    Visibility="Collapsed" />
            <!-- Corner brackets with shadow for contrast on any background -->
            <!-- Shadow lines (dark, slightly offset) -->
            <Line x:Name="TL_Hs" Stroke="#80000000" StrokeThickness="3" Visibility="Collapsed" />
            <Line x:Name="TL_Vs" Stroke="#80000000" StrokeThickness="3" Visibility="Collapsed" />
            <Line x:Name="TR_Hs" Stroke="#80000000" StrokeThickness="3" Visibility="Collapsed" />
            <Line x:Name="TR_Vs" Stroke="#80000000" StrokeThickness="3" Visibility="Collapsed" />
            <Line x:Name="BL_Hs" Stroke="#80000000" StrokeThickness="3" Visibility="Collapsed" />
            <Line x:Name="BL_Vs" Stroke="#80000000" StrokeThickness="3" Visibility="Collapsed" />
            <Line x:Name="BR_Hs" Stroke="#80000000" StrokeThickness="3" Visibility="Collapsed" />
            <Line x:Name="BR_Vs" Stroke="#80000000" StrokeThickness="3" Visibility="Collapsed" />
            <!-- Foreground lines (bright) -->
            <Line x:Name="TL_H" Stroke="#CCFFFFFF" StrokeThickness="1.5" Visibility="Collapsed" />
            <Line x:Name="TL_V" Stroke="#CCFFFFFF" StrokeThickness="1.5" Visibility="Collapsed" />
            <Line x:Name="TR_H" Stroke="#CCFFFFFF" StrokeThickness="1.5" Visibility="Collapsed" />
            <Line x:Name="TR_V" Stroke="#CCFFFFFF" StrokeThickness="1.5" Visibility="Collapsed" />
            <Line x:Name="BL_H" Stroke="#CCFFFFFF" StrokeThickness="1.5" Visibility="Collapsed" />
            <Line x:Name="BL_V" Stroke="#CCFFFFFF" StrokeThickness="1.5" Visibility="Collapsed" />
            <Line x:Name="BR_H" Stroke="#CCFFFFFF" StrokeThickness="1.5" Visibility="Collapsed" />
            <Line x:Name="BR_V" Stroke="#CCFFFFFF" StrokeThickness="1.5" Visibility="Collapsed" />
        </Canvas>
        <Canvas x:Name="FadeCanvas" IsHitTestVisible="False" />
    </Grid>
</Window>
