                                                <RepeatButton Style="{StaticResource SpinnerBtn}" Content="▲" Click="StepsSizeUp_Click" />
                                                <RepeatButton Style="{StaticResource SpinnerBtn}" Content="▼" Click="StepsSizeDown_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Border Style="{StaticResource CardSep}" />
                                <!-- Color section — 3 toggle buttons selecting which picker shows -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Color" Style="{StaticResource RowLabel}" />
                                    <Border x:Name="StepsColorFillBtn" Grid.Column="1" Height="32"
                                            Background="{StaticResource ControlBg}"
                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                            CornerRadius="4" Cursor="Hand" Margin="0,0,4,0"
                                            MouseLeftButtonDown="StepsColorTab_Click" Tag="Fill">
                                        <TextBlock Text="Fill" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                    </Border>
                                    <Border x:Name="StepsColorOutlineBtn" Grid.Column="2" Height="32"
                                            Background="{StaticResource ControlBg}"
                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                            CornerRadius="4" Cursor="Hand" Margin="0,0,4,0"
                                            MouseLeftButtonDown="StepsColorTab_Click" Tag="Outline">
                                        <TextBlock Text="Outline" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                    </Border>
                                    <Border x:Name="StepsColorFontBtn" Grid.Column="3" Height="32"
                                            Background="{StaticResource ControlBg}"
                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="StepsColorTab_Click" Tag="Font">
                                        <TextBlock Text="Font" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                    </Border>
                                </Grid>
                                <!-- Fill color panel -->
                                <StackPanel x:Name="StepsFillColorPanel">
                                    <UniformGrid x:Name="StepsFillColorPresetGrid" Rows="2" Columns="10" Margin="0,0,0,6" />
                                    <UniformGrid x:Name="StepsFillCustomColorGrid" Rows="1" Columns="10" Margin="0,0,0,8" />
                                    <Button Content="Select Custom Color..." Click="StepsFillEditColors_Click"
                                            HorizontalAlignment="Right" Padding="12,6"
                                            Cursor="Hand" FontSize="12"
                                            Foreground="{StaticResource TextPrimary}"
                                            Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{StaticResource ControlBg}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                                <!-- Outline color panel -->
                                <StackPanel x:Name="StepsOutlineColorPanel" Visibility="Collapsed">
                                    <UniformGrid x:Name="StepsOutlineColorPresetGrid" Rows="2" Columns="10" Margin="0,0,0,6" />
                                    <UniformGrid x:Name="StepsOutlineCustomColorGrid" Rows="1" Columns="10" Margin="0,0,0,8" />
                                    <Button Content="Select Custom Color..." Click="StepsOutlineEditColors_Click"
                                            HorizontalAlignment="Right" Padding="12,6"
                                            Cursor="Hand" FontSize="12"
                                            Foreground="{StaticResource TextPrimary}"
                                            Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{StaticResource ControlBg}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                                <!-- Font color panel -->
                                <StackPanel x:Name="StepsFontColorPanel" Visibility="Collapsed">
                                    <UniformGrid x:Name="StepsFontColorPresetGrid" Rows="2" Columns="10" Margin="0,0,0,6" />
                                    <UniformGrid x:Name="StepsFontCustomColorGrid" Rows="1" Columns="10" Margin="0,0,0,8" />
                                    <Button Content="Select Custom Color..." Click="StepsFontEditColors_Click"
                                            HorizontalAlignment="Right" Padding="12,6"
                                            Cursor="Hand" FontSize="12"
                                            Foreground="{StaticResource TextPrimary}"
                                            Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{StaticResource ControlBg}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Content="Reset Steps Settings" Click="ResetStepsSettings_Click"
                            HorizontalAlignment="Stretch" Padding="0,10"
                            Cursor="Hand" FontSize="13"
                            Foreground="{StaticResource TextSecondary}"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{StaticResource ControlBg}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>
