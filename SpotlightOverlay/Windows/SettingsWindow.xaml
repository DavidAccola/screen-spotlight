<Window x:Class="SpotlightOverlay.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spotlight Overlay Settings"
        Width="400"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="50" />
        </Grid.ColumnDefinitions>

        <!-- Overlay Opacity -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Overlay Opacity" FontWeight="SemiBold" Margin="0,0,0,5" />
        <Slider Grid.Row="1" Grid.Column="0"
                x:Name="OpacitySlider"
                Minimum="0.0" Maximum="1.0"
                TickFrequency="0.01"
                IsSnapToTickEnabled="True"
                ValueChanged="OpacitySlider_ValueChanged" />
        <TextBlock Grid.Row="1" Grid.Column="1"
                   x:Name="OpacityValueText"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right" />

        <!-- Feather Radius -->
        <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="Feather Radius" FontWeight="SemiBold" Margin="0,0,0,5" />
        <Slider Grid.Row="4" Grid.Column="0"
                x:Name="FeatherSlider"
                Minimum="0" Maximum="200"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="FeatherSlider_ValueChanged" />
        <TextBlock Grid.Row="4" Grid.Column="1"
                   x:Name="FeatherValueText"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right" />
    </Grid>
</Window>
