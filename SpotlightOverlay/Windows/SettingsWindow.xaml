                                                <RepeatButton Style="{StaticResource SpinnerBtn}" Content="▲" Click="StepsFontSizeUp_Click" />
                                                <RepeatButton Style="{StaticResource SpinnerBtn}" Content="▼" Click="StepsFontSizeDown_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
