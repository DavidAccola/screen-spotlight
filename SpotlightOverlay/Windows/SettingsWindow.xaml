                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="StepsShapeToggle_Click" Tag="Circle">
                                        <TextBlock Text="Circle" HorizontalAlignment="Center" VerticalAlignment="Center"
