                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="18" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="StepsFontSizeTextBox"
                                                     Style="{StaticResource SpinnerTextBox}"
                                                     LostFocus="StepsFontSizeTextBox_LostFocus"
                                                     KeyDown="StepsFontSizeTextBox_KeyDown" />
