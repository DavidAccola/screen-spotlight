                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                            CornerRadius="4" Cursor="Hand" Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            MouseLeftButtonDown="StepsBoldBtn_Click">
