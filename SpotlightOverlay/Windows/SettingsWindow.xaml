<Window x:Class="SpotlightOverlay.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spotlight Overlay Settings"
        Width="520" Height="800"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#2D2D2D" />
        <SolidColorBrush x:Key="CardBorder" Color="#3E3E3E" />
        <SolidColorBrush x:Key="TextPrimary" Color="#E0E0E0" />
        <SolidColorBrush x:Key="TextSecondary" Color="#999999" />
        <SolidColorBrush x:Key="TextMuted" Color="#707070" />
        <SolidColorBrush x:Key="Accent" Color="#5B9BD5" />
        <SolidColorBrush x:Key="ControlBg" Color="#383838" />
        <SolidColorBrush x:Key="ControlHover" Color="#434343" />
        <Style x:Key="H1" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="2,0,0,6" />
        </Style>
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="10" />
        </Style>
        <Style x:Key="DarkThumb" TargetType="Thumb">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="{StaticResource Accent}" Stroke="#1E1E1E" StrokeThickness="2" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SliderFill" TargetType="RepeatButton">
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{StaticResource Accent}" CornerRadius="2" Height="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SliderTrack" TargetType="RepeatButton">
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="#4D4D4D" CornerRadius="2" Height="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Height" Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderFill}" Command="Slider.DecreaseLarge" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderTrack}" Command="Slider.IncreaseLarge" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                CornerRadius="4" Padding="6,4">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComboToggle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{StaticResource ControlBg}"
                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="4">
                            <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="{StaticResource TextSecondary}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="Check" Grid.Column="0" Text="✓"
                                           Foreground="{StaticResource Accent}" FontSize="12"
                                           VerticalAlignment="Center" Visibility="Collapsed" />
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E3E3E" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Height" Value="32" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Style="{StaticResource ComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press" />
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False" Margin="4,0,4,0"
                                              VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}" SnapsToDevicePixels="True">
                                    <Border Background="#333333" BorderBrush="{StaticResource CardBorder}"
                                            BorderThickness="1" CornerRadius="4" Margin="4,2,4,4" Padding="0,4">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.6" />
                                        </Border.Effect>
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardSep" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{StaticResource CardBorder}" />
            <Setter Property="Margin" Value="0,8" />
        </Style>

        <!-- Dark mode toggle switch -->
        <Style x:Key="DarkToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="36" Height="20">
                                <Border x:Name="Track" CornerRadius="10" Background="#4D4D4D" />
                                <Border x:Name="Thumb" Width="16" Height="16" CornerRadius="8"
                                        Background="#999999" HorizontalAlignment="Left" Margin="2,0,0,0" />
                            </Grid>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Accent}" />
                                <Setter TargetName="Thumb" Property="Background" Value="White" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.3" />
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Spinner inline TextBox (no border, transparent) -->
        <Style x:Key="SpinnerTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark mode numeric spinner (up/down buttons) -->
        <Style x:Key="SpinnerBtn" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="8" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabControl style for dark theme -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="16,8" Margin="0,0,2,0"
                                Background="Transparent" BorderThickness="0,0,0,2"
                                BorderBrush="Transparent" Cursor="Hand">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource Accent}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="#2A2A2A" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <TabControl Margin="0,8,0,0">
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- GENERAL TAB                                            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TabItem Header="General" IsSelected="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="16,14,16,16">

                    <!-- ═══ BEHAVIOR section ═══ -->
                    <TextBlock Text="BEHAVIOR" Style="{StaticResource H1}" />
                    <Border Background="{StaticResource CardBg}" CornerRadius="6"
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                            Padding="14,10" Margin="0,0,0,14">
                        <StackPanel>
                            <!-- Drag Mode -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Drag Mode" Style="{StaticResource RowLabel}" />
                                <ComboBox Grid.Column="1" x:Name="DragStyleCombo"
                                          SelectionChanged="DragStyleCombo_SelectionChanged">
                                    <ComboBoxItem x:Name="DragStyleHold" Content="Hold and Drag" />
                                    <ComboBoxItem x:Name="DragStyleClick" Content="Click to Click" />
                                </ComboBox>
                            </Grid>
                            <Border Style="{StaticResource CardSep}" />
                            <!-- Background mode -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Background" Style="{StaticResource RowLabel}" />
                                <ComboBox Grid.Column="1" x:Name="BackgroundCombo"
                                          SelectionChanged="BackgroundCombo_SelectionChanged">
                                    <ComboBoxItem Content="Live background" />
                                    <ComboBoxItem Content="Freeze background" />
                                </ComboBox>
                            </Grid>
                            <Border Style="{StaticResource CardSep}" />
                            <!-- Fade screen mode -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Fade screen" Style="{StaticResource RowLabel}" />
                                <ComboBox Grid.Column="1" x:Name="FadeModeCombo"
                                          SelectionChanged="FadeModeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Immediately" />
                                    <ComboBoxItem Content="After the spotlight" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ═══ HOTKEYS section ═══ -->
                    <TextBlock Text="HOTKEYS" Style="{StaticResource H1}" />
                    <Border Background="{StaticResource CardBg}" CornerRadius="6"
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                            Padding="14,10" Margin="0,0,0,14">
                        <StackPanel>
                            <!-- Activation Key -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Activation" Style="{StaticResource RowLabel}" />
                                <StackPanel Grid.Column="1">
                                    <Border x:Name="HotkeyRecorderBorder"
                                            Background="{StaticResource ControlBg}"
                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                            CornerRadius="4" Padding="10,6" Cursor="Hand"
                                            MouseLeftButtonDown="HotkeyRecorder_Click">
                                        <TextBlock x:Name="HotkeyDisplay"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13" Text="Ctrl + Shift + Click" />
                                    </Border>
                                    <TextBlock x:Name="HotkeyHint" Margin="0,3,0,0"
                                               Style="{StaticResource HintText}"
                                               Text="Click to change, then press a modifier key" />
                                </StackPanel>
                            </Grid>
                            <Border Style="{StaticResource CardSep}" />
                            <!-- Toggle Tool Hotkey -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Toggle tool" Style="{StaticResource RowLabel}" />
                                <StackPanel Grid.Column="1">
                                    <Border x:Name="ToggleToolHotkeyBorder"
                                            Background="{StaticResource ControlBg}"
                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                            CornerRadius="4" Padding="10,6" Cursor="Hand"
                                            MouseLeftButtonDown="ToggleToolHotkeyRecorder_Click">
                                        <TextBlock x:Name="ToggleToolHotkeyDisplay"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13" Text="Ctrl + Shift + Right Click" />
                                    </Border>
                                    <TextBlock x:Name="ToggleToolHotkeyHint" Margin="0,3,0,0"
                                               Style="{StaticResource HintText}"
                                               Text="Click to change — press keys or mouse buttons" />
                                </StackPanel>
                            </Grid>
                            <Border Style="{StaticResource CardSep}" />
                            <!-- Toggle Hotkey -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Toggle On/Off" Style="{StaticResource RowLabel}" />
                                <StackPanel Grid.Column="1">
                                    <Border x:Name="ToggleHotkeyBorder"
                                            Background="{StaticResource ControlBg}"
                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                            CornerRadius="4" Padding="10,6" Cursor="Hand"
                                            MouseLeftButtonDown="ToggleHotkeyRecorder_Click">
                                        <TextBlock x:Name="ToggleHotkeyDisplay"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13" Text="Ctrl + Shift + Q" />
                                    </Border>
                                    <TextBlock x:Name="ToggleHotkeyHint" Margin="0,3,0,0"
                                               Style="{StaticResource HintText}"
                                               Text="Click to change, then press modifier(s) + key" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Reset ═══ -->
                    <Button Content="Reset General Settings" Click="ResetGeneralSettings_Click"
                            HorizontalAlignment="Stretch" Padding="0,10"
                            Cursor="Hand" FontSize="13"
                            Foreground="{StaticResource TextSecondary}"
                            Background="Transparent" BorderThickness="0" Margin="0,0,0,6">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{StaticResource ControlBg}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Reset All Settings" Click="ResetDefaults_Click"
                            HorizontalAlignment="Stretch" Padding="0,10"
                            Cursor="Hand" FontSize="13"
                            Foreground="{StaticResource TextSecondary}"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{StaticResource ControlBg}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SPOTLIGHT TAB                                          -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TabItem Header="Spotlight">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="16,14,16,16">

                    <!-- ═══ APPEARANCE section — preview is inside this card ═══ -->
                    <TextBlock Text="APPEARANCE" Style="{StaticResource H1}" />
                    <Border Background="{StaticResource CardBg}" CornerRadius="6"
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                            Padding="0" Margin="0,0,0,14" ClipToBounds="True">
                        <StackPanel>
                            <!-- Preview canvas at top of card, no side padding -->
                            <Border ClipToBounds="True" Background="#0068BE">
                                <Canvas x:Name="PreviewArea" Height="110">
                                    <Canvas.Background>
                                        <ImageBrush ImageSource="/assets/background.png"
                                                    Stretch="Uniform"
                                                    AlignmentX="Center" AlignmentY="Center"
                                                    Viewport="-0.02,0.08,1.04,0.84"
                                                    ViewportUnits="RelativeToBoundingBox" />
                                    </Canvas.Background>
                                </Canvas>
                            </Border>
                            <StackPanel Margin="14,10,14,10">
                                <!-- Opacity -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="76" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Transparency" Style="{StaticResource RowLabel}" />
                                    <Slider Grid.Column="1" x:Name="OpacitySlider"
                                            Minimum="10" Maximum="90" TickFrequency="10"
                                            IsSnapToTickEnabled="True" LargeChange="10" SmallChange="1"
                                            VerticalAlignment="Center" Margin="0,0,10,0"
                                            ValueChanged="OpacitySlider_ValueChanged" />
                                    <Border Grid.Column="2" VerticalAlignment="Center"
                                            Background="{StaticResource ControlBg}"
                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="18" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="OpacityTextBox"
                                                     Style="{StaticResource SpinnerTextBox}"
                                                     LostFocus="OpacityTextBox_LostFocus" KeyDown="OpacityTextBox_KeyDown" />
                                            <StackPanel Grid.Column="1">
                                                <RepeatButton Style="{StaticResource SpinnerBtn}" Content="▲" Click="OpacityUp_Click" />
                                                <RepeatButton Style="{StaticResource SpinnerBtn}" Content="▼" Click="OpacityDown_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Border Style="{StaticResource CardSep}" />
                                <!-- Feather -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="76" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Blurred Edges" Style="{StaticResource RowLabel}" />
                                    <Slider Grid.Column="1" x:Name="FeatherSlider"
                                            Minimum="0" Maximum="50" TickFrequency="10"
                                            IsSnapToTickEnabled="False" LargeChange="10" SmallChange="1"
                                            VerticalAlignment="Center" Margin="0,0,10,0"
                                            ValueChanged="FeatherSlider_ValueChanged" />
                                    <Border Grid.Column="2" VerticalAlignment="Center"
                                            Background="{StaticResource ControlBg}"
                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="18" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="FeatherTextBox"
                                                     Style="{StaticResource SpinnerTextBox}"
                                                     LostFocus="FeatherTextBox_LostFocus" KeyDown="FeatherTextBox_KeyDown" />
                                            <StackPanel Grid.Column="1">
                                                <RepeatButton Style="{StaticResource SpinnerBtn}" Content="▲" Click="FeatherUp_Click" />
                                                <RepeatButton Style="{StaticResource SpinnerBtn}" Content="▼" Click="FeatherDown_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Border Style="{StaticResource CardSep}" />
                                <!-- Preview Style -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Preview Style" Style="{StaticResource RowLabel}" />
                                    <ComboBox Grid.Column="1" x:Name="PreviewStyleCombo"
                                              SelectionChanged="PreviewStyleCombo_SelectionChanged">
                                        <ComboBoxItem Content="Outline" />
                                        <ComboBoxItem Content="Crop Marks" />
                                        <ComboBoxItem Content="Half Crop Marks (2/4 corners)" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ BEHAVIOR section ═══ -->
                    <TextBlock Text="BEHAVIOR" Style="{StaticResource H1}" />
                    <Border Background="{StaticResource CardBg}" CornerRadius="6"
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                            Padding="14,10" Margin="0,0,0,14">
                        <StackPanel>
                            <!-- Spotlight Mode -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}">
                                    <Run Text="2"/><Run Text="nd" FontSize="9" BaselineAlignment="TextTop"/><Run Text=" Spotlight"/>
                                </TextBlock>
                                <StackPanel Grid.Column="1">
                                    <ComboBox x:Name="SpotlightModeCombo"
                                              SelectionChanged="SpotlightModeCombo_SelectionChanged">
                                        <ComboBoxItem Content="Stack" />
                                        <ComboBoxItem Content="Replace" />
                                    </ComboBox>
                                    <TextBlock x:Name="SpotlightModeHint" Margin="0,3,0,0"
                                               Style="{StaticResource HintText}"
                                               Foreground="{StaticResource TextSecondary}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Button Content="Reset Spotlight Settings" Click="ResetSpotlightSettings_Click"
                            HorizontalAlignment="Stretch" Padding="0,10"
                            Cursor="Hand" FontSize="13"
                            Foreground="{StaticResource TextSecondary}"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{StaticResource ControlBg}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- ARROW TAB                                              -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TabItem Header="Arrow">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="16,14,16,16">

                    <!-- ═══ APPEARANCE section ═══ -->
                    <TextBlock Text="APPEARANCE" Style="{StaticResource H1}" />
                    <Border Background="{StaticResource CardBg}" CornerRadius="6"
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                            Padding="0" Margin="0,0,0,14" ClipToBounds="True">
                        <StackPanel>
                            <!-- Arrow preview at top of card -->
                            <Border ClipToBounds="True" Background="#001A30">
                                <Canvas x:Name="ArrowPreviewArea" Height="110" />
                            </Border>
                            <StackPanel Margin="14,10,14,10">
                            <!-- Style + Size share one Grid for perfect column alignment -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="4*" />
                                    <ColumnDefinition Width="3*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <!-- Row 0: Style combos -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Style" Style="{StaticResource RowLabel}" />
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="LeftEndCombo" Height="36"
                                          SelectionChanged="ArrowStyleCombo_SelectionChanged" />
                                <ComboBox Grid.Row="0" Grid.Column="2" x:Name="LineStyleCombo" Height="36" Margin="4,0"
                                          SelectionChanged="ArrowStyleCombo_SelectionChanged" />
                                <ComboBox Grid.Row="0" Grid.Column="3" x:Name="RightEndCombo" Height="36"
                                          SelectionChanged="ArrowStyleCombo_SelectionChanged" />
                                <!-- Row 1: Sync style toggle -->
                                <CheckBox x:Name="SyncStyleCheck" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                          Style="{StaticResource DarkToggle}"
                                          Content="Match arrow ends"
                                          Foreground="{StaticResource TextPrimary}" FontSize="13"
                                          Margin="0,6,0,0"
                                          Checked="SyncStyleCheck_Changed" Unchecked="SyncStyleCheck_Changed" />                                <!-- Row 2: Divider -->
                                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                                        Height="1" Background="{StaticResource CardBorder}" Margin="0,8" />
                                <!-- Row 3: Size toggles -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Size" Style="{StaticResource RowLabel}" />
                                <Border x:Name="SizeLeftBtn" Grid.Row="3" Grid.Column="1" Height="36"
                                        Background="{StaticResource ControlBg}"
                                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                        CornerRadius="4" Cursor="Hand"
                                        MouseLeftButtonDown="SizeToggle_Click" Tag="Left">
                                    <ContentPresenter x:Name="SizeLeftContent" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <Border x:Name="SizeLineBtn" Grid.Row="3" Grid.Column="2" Height="36"
                                        Background="{StaticResource ControlBg}"
                                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                        CornerRadius="4" Cursor="Hand" Margin="4,0"
                                        MouseLeftButtonDown="SizeToggle_Click" Tag="Line">
                                    <ContentPresenter x:Name="SizeLineContent" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <Border x:Name="SizeRightBtn" Grid.Row="3" Grid.Column="3" Height="36"
                                        Background="{StaticResource ControlBg}"
                                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                        CornerRadius="4" Cursor="Hand"
                                        MouseLeftButtonDown="SizeToggle_Click" Tag="Right">
                                    <ContentPresenter x:Name="SizeRightContent" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <!-- Row 4: Size sync toggle (under slider) -->
                                <!-- Row 5: Size slider -->
                                <Slider Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" x:Name="SizeSlider"
                                        Minimum="8" Maximum="60" TickFrequency="2" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" Margin="0,6,56,0"
                                        ValueChanged="SizeSlider_ValueChanged" />
                                <Border Grid.Row="4" Grid.Column="3" VerticalAlignment="Center"
                                        HorizontalAlignment="Right" Margin="0,6,0,0"
                                        Background="{StaticResource ControlBg}"
                                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                        CornerRadius="4" Width="56">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="18" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="SizeTextBox"
                                                 Style="{StaticResource SpinnerTextBox}"
                                                 LostFocus="SizeTextBox_LostFocus" KeyDown="SizeTextBox_KeyDown" />
                                        <StackPanel Grid.Column="1">
                                            <RepeatButton Style="{StaticResource SpinnerBtn}" Content="▲" Click="SizeUp_Click" />
                                            <RepeatButton Style="{StaticResource SpinnerBtn}" Content="▼" Click="SizeDown_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <CheckBox x:Name="SyncSizeCheck" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3"
                                          Style="{StaticResource DarkToggle}"
                                          Content="Match arrow ends"
                                          Foreground="{StaticResource TextPrimary}" FontSize="13"
                                          Margin="0,6,0,0"
                                          Checked="SyncSizeCheck_Changed" Unchecked="SyncSizeCheck_Changed" />
                            </Grid>
                            <Border Style="{StaticResource CardSep}" />
                            <!-- Color -->
                            <TextBlock Text="Color" Style="{StaticResource RowLabel}" Margin="0,0,0,8" />
                            <!-- Preset colors: 2 rows of 10 -->
                            <UniformGrid x:Name="ColorPresetGrid" Rows="2" Columns="10" Margin="0,0,0,6" />
                            <!-- Custom color slots: 1 row of 10 -->
                            <UniformGrid x:Name="CustomColorGrid" Rows="1" Columns="10" Margin="0,0,0,8" />
                            <!-- Edit Colors button -->
                            <Button Content="Select Custom Color..." Click="EditColors_Click"
                                    HorizontalAlignment="Right" Padding="12,6"
                                    Cursor="Hand" FontSize="12"
                                    Foreground="{StaticResource TextPrimary}"
                                    Background="Transparent" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{StaticResource ControlBg}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Content="Reset Arrow Settings" Click="ResetArrowSettings_Click"
                            HorizontalAlignment="Stretch" Padding="0,10"
                            Cursor="Hand" FontSize="13"
                            Foreground="{StaticResource TextSecondary}"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{StaticResource ControlBg}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- BOX TAB                                                -->
